# CommerceLens hosted product configuration

# Runtime
COMMERCELENS_ENV=development
COMMERCELENS_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Storage
COMMERCELENS_STORE_BACKEND=sqlite
COMMERCELENS_JOBS_DB=commercelens_jobs.db
# COMMERCELENS_STORE_BACKEND=postgres
# COMMERCELENS_DATABASE_URL=postgresql://user:password@localhost:5432/commercelens

# Auth
COMMERCELENS_REQUIRE_API_KEY=false
COMMERCELENS_ADMIN_TOKEN=replace-with-long-random-secret

# Fetching and crawl posture
COMMERCELENS_USER_AGENT=CommerceLens/0.9 (+mailto:ops@example.com)
COMMERCELENS_DEFAULT_TIMEOUT_SECONDS=20

# Alerts
# COMMERCELENS_SMTP_HOST=smtp.example.com
# COMMERCELENS_SMTP_PORT=587
# COMMERCELENS_SMTP_USERNAME=
# COMMERCELENS_SMTP_PASSWORD=
# COMMERCELENS_SMTP_FROM=alerts@example.com

# Billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
